# Copy this file to .env and fill in your values

# Path to theoria-dataset (required)
THEORIA_DATASET_PATH=

# AWS Bedrock Configuration
AWS_REGION=us-east-1

# Model ARNs - get these from your AWS Bedrock console
# Format: arn:aws:bedrock:<region>:<account>:inference-profile/<profile-name>
# Or use model IDs like: anthropic.claude-3-haiku-20240307-v1:0
BEDROCK_MODEL_FAST=
BEDROCK_MODEL_BEST=
